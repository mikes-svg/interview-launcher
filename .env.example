# Vapi public/web key (NOT the private server key).
# Vapi Dashboard → API Keys → Public Key.
VITE_VAPI_PUBLIC_KEY=

# Default Vapi assistant ID (UUID). Used when ?position= is missing or unknown.
VITE_VAPI_ASSISTANT_ID=

# Display name of the AI interviewer — must match the name configured in the assistant.
VITE_INTERVIEWER_NAME=Alex

# Heading shown at the top of the launcher.
VITE_COMPANY_NAME=Screening Interview

# Optional: extra positions, as a JSON array. Each entry needs slug, label, assistantId.
# The default assistant above is always available — only add this if you have multiple roles.
# VITE_POSITIONS=[{"slug":"ops-manager","label":"Operations Manager","assistantId":"00000000-0000-0000-0000-000000000000"}]
